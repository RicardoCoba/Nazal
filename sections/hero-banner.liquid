{%- style -%}
  .hero-slider-height {
    height: 80vh;
  }
{%- endstyle -%}

<div class="relative overflow-hidden bg-black hero-slider-height">
  <div class="flex h-full transition-transform duration-700 ease-[cubic-bezier(0.45,0,0.55,1)]" id="HeroSlider">
    {%- for block in section.blocks -%}
      <div class="min-w-full h-full relative flex-shrink-0" {{ block.shopify_attributes }}>
        {%- comment -%} MEDIA (Video o Imagen) {%- endcomment -%}
        {%- if block.settings.video_url != blank -%}
          {{
            block.settings.video_url
            | video_tag:
              autoplay: true,
              loop: true,
              muted: true,
              controls: false,
              class: 'absolute inset-0 w-full h-full object-cover'
          }}
        {%- elsif block.settings.image != blank -%}
          <img
            src="{{ block.settings.image | image_url: width: 2000 }}"
            class="absolute inset-0 w-full h-full object-cover"
            loading="lazy"
            alt="{{ block.settings.image.alt }}"
          >
        {%- endif -%}

        {%- comment -%}
          CONTENEDOR DE TEXTO DINÁMICO
          Usamos las clases de alineación que vienen del schema
        {%- endcomment -%}
        <div class="absolute inset-0 bg-black/30 flex {{ block.settings.vertical_alignment }} {{ block.settings.horizontal_alignment }} p-8 md:p-20">
          <div class="{{ block.settings.text_align }} max-w-2xl">
            <h2 class="text-white text-5xl md:text-8xl font-black uppercase italic tracking-tighter leading-none mb-4 drop-shadow-lg">
              {{ block.settings.title }}
            </h2>
            <p class="text-white text-lg md:text-2xl font-medium mb-8 drop-shadow-md">
              {{ block.settings.subtext }}
            </p>
            {%- if block.settings.button_link != blank -%}
              <a
                href="{{ block.settings.button_link }}"
                class="inline-block bg-white text-black hover:bg-black hover:text-white px-10 py-4 font-bold uppercase tracking-widest transition-all duration-300 transform hover:scale-105"
              >
                {{ block.settings.button_label }}
              </a>
            {%- endif -%}
          </div>
        </div>
      </div>
    {%- endfor -%}
  </div>

  {%- comment -%} Flechas de navegación {%- endcomment -%}
  <div class="absolute bottom-10 right-10 flex gap-4 z-20">
    <button
      onclick="moveSlider(-1)"
      class="border border-white/50 hover:bg-white hover:text-black p-4 text-white transition-all"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
    </button>
    <button
      onclick="moveSlider(1)"
      class="border border-white/50 hover:bg-white hover:text-black p-4 text-white transition-all"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
    </button>
  </div>
</div>

<script>
  let currentSlide = 0;
  function moveSlider(direction) {
    const slider = document.getElementById('HeroSlider');
    const totalSlides = slider.children.length;
    currentSlide = (currentSlide + direction + totalSlides) % totalSlides;
    slider.style.transform = `translateX(-${currentSlide * 100}%)`;
  }
</script>

{% schema %}
{
  "name": "Hero Video Slider PRO",
  "max_blocks": 3,
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Imagen" },
        { "type": "video", "id": "video_url", "label": "Video" },
        { "type": "text", "id": "title", "label": "Título", "default": "TITULO IMPACTANTE" },
        { "type": "text", "id": "subtext", "label": "Subtítulo", "default": "Describe tu marca aquí" },
        { "type": "url", "id": "button_link", "label": "Link" },
        { "type": "text", "id": "button_label", "label": "Botón", "default": "COMPRAR" },
        {
          "type": "header",
          "content": "Posicionamiento del Texto"
        },
        {
          "type": "select",
          "id": "horizontal_alignment",
          "label": "Alineación Horizontal",
          "options": [
            { "value": "justify-start", "label": "Izquierda" },
            { "value": "justify-center", "label": "Centro" },
            { "value": "justify-end", "label": "Derecha" }
          ],
          "default": "justify-center"
        },
        {
          "type": "select",
          "id": "vertical_alignment",
          "label": "Alineación Vertical",
          "options": [
            { "value": "items-start", "label": "Arriba" },
            { "value": "items-center", "label": "Centro" },
            { "value": "items-end", "label": "Abajo" }
          ],
          "default": "items-center"
        },
        {
          "type": "select",
          "id": "text_align",
          "label": "Alineación del Texto",
          "options": [
            { "value": "text-left", "label": "Izquierda" },
            { "value": "text-center", "label": "Centro" },
            { "value": "text-right", "label": "Derecha" }
          ],
          "default": "text-center"
        }
      ]
    }
  ],
  "presets": [{ "name": "Hero Video Slider PRO" }]
}
{% endschema %}
