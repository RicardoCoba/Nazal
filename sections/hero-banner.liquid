{%- style -%}
  .hero-slider-{{ section.id }} {
    {% if section.settings.height_mode == 'full' %}
      height: 100vh;
    {% elsif section.settings.height_mode == 'custom' %}
      height: {{ section.settings.custom_height }}px;
    {% else %}
      aspect-ratio: {{ section.blocks.first.settings.image.aspect_ratio | default: '16/9' }};
      height: auto;
    {% endif %}
    cursor: pointer;
  }

  @media screen and (max-width: 768px) {
    .hero-slider-{{ section.id }} {
      height: {{ section.settings.mobile_height }}px;
      aspect-ratio: auto;
    }
  }

  .cover-overlay-{{ section.id }} {
    transition: opacity 0.8s cubic-bezier(0.4, 0, 0.2, 1), visibility 0.8s;
    z-index: 20;
    background-color: #000;
  }

  .cover-overlay-{{ section.id }}.is-hidden {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  /* Animación del botón de Play */
  .play-button-wrapper {
    transition: transform 0.3s ease;
  }
  .play-button-wrapper:hover {
    transform: scale(1.1);
  }

  .pulse-animation {
    animation: pulse-white 2s infinite;
    border-radius: 50%;
  }

  @keyframes pulse-white {
    0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(255, 255, 255, 0.7); }
    70% { transform: scale(1); box-shadow: 0 0 0 20px rgba(255, 255, 255, 0); }
    100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(255, 255, 255, 0); }
  }
{%- endstyle -%}

<div
  class="relative overflow-hidden bg-black hero-slider-{{ section.id }}"
  id="HeroContainer-{{ section.id }}"
  onclick="startHeroExperience(this)"
>
  <div class="flex h-full w-full">
    {%- for block in section.blocks -%}
      <div class="min-w-full h-full relative flex-shrink-0" {{ block.shopify_attributes }}>
        {%- if block.settings.video_url != blank -%}
          {{
            block.settings.video_url
            | video_tag:
              autoplay: false,
              loop: true,
              muted: true,
              controls: false,
              id: 'HeroVideo',
              class: 'absolute inset-0 w-full h-full object-cover z-0'
          }}
        {%- endif -%}

        <div class="cover-overlay-{{ section.id }} absolute inset-0 flex flex-col items-center justify-center text-center">
          {%- if block.settings.video_poster != blank -%}
            <img
              src="{{ block.settings.video_poster | image_url: width: 2000 }}"
              class="absolute inset-0 w-full h-full object-cover z-10 opacity-60"
              loading="eager"
            >
          {%- endif -%}

          <div class="relative z-30 px-6 max-w-4xl">
            <div class="play-button-wrapper mb-8 flex justify-center">
              <div class="pulse-animation bg-white/20 p-6 backdrop-blur-sm border border-white/30">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="white" xmlns="http://www.w3.org/2000/svg">
                  <path d="M8 5V19L19 12L8 5Z" />
                </svg>
              </div>
            </div>

            <h2 class="text-white text-5xl md:text-8xl font-black uppercase italic tracking-tighter leading-[0.9] mb-4 drop-shadow-2xl">
              {{ block.settings.title }}
            </h2>
            <p class="text-white text-lg md:text-2xl font-light mb-0 drop-shadow-md">
              {{ block.settings.subtext }}
            </p>
          </div>
        </div>
      </div>
    {%- endfor -%}
  </div>
</div>

<script>
  function startHeroExperience(container) {
    // 1. Ocultar la portada
    const overlay = container.querySelector('.cover-overlay-{{ section.id }}');
    overlay.classList.add('is-hidden');

    // 2. Darle play al video
    const video = container.querySelector('#HeroVideo');
    if (video) {
      video.play();
    }
  }
</script>

{% schema %}
{
  "name": "Hero Play Video Cover",
  "max_blocks": 1,
  "settings": [
    { "type": "header", "content": "Altura" },
    {
      "type": "select",
      "id": "height_mode",
      "label": "Modo de Altura",
      "options": [
        { "value": "full", "label": "Pantalla Completa" },
        { "value": "custom", "label": "Altura Personalizada" }
      ],
      "default": "custom"
    },
    {
      "type": "range",
      "id": "custom_height",
      "min": 400,
      "max": 1000,
      "step": 10,
      "unit": "px",
      "label": "Desktop",
      "default": 700
    },
    {
      "type": "range",
      "id": "mobile_height",
      "min": 300,
      "max": 800,
      "step": 10,
      "unit": "px",
      "label": "Móvil",
      "default": 500
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        { "type": "video", "id": "video_url", "label": "Video de Fondo" },
        { "type": "image_picker", "id": "video_poster", "label": "Imagen de Portada" },
        { "type": "text", "id": "title", "label": "Título", "default": "THE COLLECTION" },
        { "type": "text", "id": "subtext", "label": "Subtítulo", "default": "Haga clic para reproducir" }
      ]
    }
  ],
  "presets": [{ "name": "Hero Play Video Cover" }]
}
{% endschema %}
