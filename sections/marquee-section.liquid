{%- style -%}
  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .animate-marquee-{{ section.id }} {
    display: flex;
    width: max-content;
    animation: marquee {{ section.settings.speed }}s linear infinite;
  }

  .marquee-text-{{ section.id }} {
    color: {{ section.settings.text_color }};
    font-size: {{ section.settings.font_size_mobile }}px;
    font-weight: {{ section.settings.font_weight }};
    text-transform: {{ section.settings.text_transform }};
    font-style: {{ section.settings.font_style }};
    line-height: 1;
    display: flex;
    align-items: center;
    gap: {{ section.settings.gap }}px;
    padding-right: {{ section.settings.gap }}px; /* Espacio entre el fin de una vuelta y el inicio de otra */
  }

  @media screen and (min-width: 750px) {
    .marquee-text-{{ section.id }} {
      font-size: {{ section.settings.font_size_desktop }}px;
    }
  }

  {{ section.settings.font_family | font_face }}
  .font-custom-{{ section.id }} {
    font-family: {{ section.settings.font_family.family }}, {{ section.settings.font_family.fallback_families }};
  }
{%- endstyle -%}

<div
  class="marquee-container overflow-hidden py-6 border-y border-white/10"
  style="background-color: {{ section.settings.bg_color }};"
>
  <div class="animate-marquee-{{ section.id }}">
    {%- comment -%}
      Capa 1: Repetición para el efecto infinito de CSS (obligatorio 2 veces)
    {%- endcomment -%}
    {%- for i in (1..2) -%}
      <div class="flex items-center">
        {%- comment -%}
          Capa 2: Repetición manual definida por el usuario
        {%- endcomment -%}
        {%- assign repeat_count = section.settings.repeat_items -%}
        {%- for j in (1..repeat_count) -%}
          {%- for block in section.blocks -%}
            <div
              class="marquee-text-{{ section.id }} font-custom-{{ section.id }} flex-shrink-0"
              {{ block.shopify_attributes }}
            >
              {%- if block.settings.image != blank -%}
                <img
                  src="{{ block.settings.image | image_url: width: 200 }}"
                  alt="{{ block.settings.text }}"
                  style="height: {{ section.settings.img_height }}px; width: auto; object-contain;"
                  loading="lazy"
                >
              {%- endif -%}
              {%- if block.settings.text != blank -%}
                <span>{{ block.settings.text }}</span>
              {%- endif -%}
            </div>
          {%- endfor -%}
        {%- endfor -%}
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Marquee",
  "settings": [
    {
      "type": "header",
      "content": "Configuración de Bucle"
    },
    {
      "type": "range",
      "id": "repeat_items",
      "min": 1,
      "max": 20,
      "step": 1,
      "label": "Número de repeticiones de los bloques",
      "info": "Multiplica tus bloques para llenar el ancho de pantalla y que el loop sea fluido.",
      "default": 5
    },
    {
      "type": "range",
      "id": "speed",
      "min": 2,
      "max": 100,
      "step": 2,
      "unit": "s",
      "label": "Velocidad (Segundos)",
      "default": 20
    },
    { "type": "header", "content": "Colores y Fuente" },
    { "type": "color", "id": "bg_color", "label": "Color de Fondo", "default": "#000000" },
    { "type": "color", "id": "text_color", "label": "Color de Texto", "default": "#ffffff" },
    { "type": "font_picker", "id": "font_family", "label": "Fuente", "default": "assistant_n4" },
    { "type": "header", "content": "Tamaños y Estilo" },
    {
      "type": "range",
      "id": "font_size_desktop",
      "min": 20,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Tamaño Desktop",
      "default": 60
    },
    {
      "type": "range",
      "id": "font_size_mobile",
      "min": 10,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Tamaño Mobile",
      "default": 30
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Grosor",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "700", "label": "Bold" },
        { "value": "900", "label": "Black" }
      ],
      "default": "900"
    },
    {
      "type": "select",
      "id": "text_transform",
      "label": "Transformación",
      "options": [
        { "value": "none", "label": "Normal" },
        { "value": "uppercase", "label": "MAYÚSCULAS" }
      ],
      "default": "uppercase"
    },
    {
      "type": "select",
      "id": "font_style",
      "label": "Estilo",
      "options": [
        { "value": "normal", "label": "Normal" },
        { "value": "italic", "label": "Itálica" }
      ],
      "default": "italic"
    },
    {
      "type": "range",
      "id": "gap",
      "min": 10,
      "max": 200,
      "step": 10,
      "unit": "px",
      "label": "Espacio (Gap)",
      "default": 80
    },
    {
      "type": "range",
      "id": "img_height",
      "min": 20,
      "max": 200,
      "step": 10,
      "unit": "px",
      "label": "Altura Iconos",
      "default": 50
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Elemento",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Imagen/Icono" },
        { "type": "text", "id": "text", "label": "Texto", "default": "NUEVO DROP" }
      ]
    }
  ],
  "presets": [{ "name": "Marquee Auto-Repeat" }]
}
{% endschema %}
