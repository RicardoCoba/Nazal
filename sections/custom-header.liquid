{%- style -%}
  .custom-header-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_vertical }}px 0;
    position: {{ section.settings.sticky_header }};
    top: 0;
    z-index: 1000;
    width: 100%;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }

  .header-grid-{{ section.id }} {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: {{ section.settings.vertical_alignment }}; /* Control Vertical */
    min-height: {{ section.settings.header_min_height }}px;
  }

  .nav-group-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: {{ section.settings.gap_links }}px;
    justify-content: {{ section.settings.horizontal_alignment }}; /* Control Horizontal */
  }

  .header-nav-link-{{ section.id }} {
    color: {{ section.settings.text_color }} !important;
    font-size: {{ section.settings.font_size }}px;
    font-weight: {{ section.settings.font_weight }};
    text-transform: {{ section.settings.text_transform }};
    font-style: {{ section.settings.font_style }};
    text-decoration: none;
    white-space: nowrap;
    transition: all 0.3s ease;
  }

  .header-nav-link-{{ section.id }}:hover {
    opacity: 0.6;
    transform: translateY(-1px);
  }

  {{ section.settings.font_family | font_face }}
  .font-header-{{ section.id }} {
    font-family: {{ section.settings.font_family.family }}, {{ section.settings.font_family.fallback_families }};
  }
{%- endstyle -%}

<header class="custom-header-{{ section.id }} font-header-{{ section.id }}">
  <div class="container mx-auto px-6">
    <div class="header-grid-{{ section.id }}">
      <nav class="nav-group-{{ section.id }}" style="justify-content: flex-start;">
        {%- for link in section.settings.menu_left.links -%}
          <a href="{{ link.url }}" class="header-nav-link-{{ section.id }}">
            {{ link.title }}
          </a>
        {%- endfor -%}
      </nav>

      <div class="flex justify-center items-center">
        <a href="{{ routes.root_url }}" class="flex items-center">
          {%- if section.settings.logo != blank -%}
            <img
              src="{{ section.settings.logo | image_url: width: 500 }}"
              alt="{{ shop.name }}"
              style="width: {{ section.settings.logo_width }}px; height: auto; display: block;"
            >
          {%- else -%}
            <span style="color: {{ section.settings.text_color }}; font-size: 1.8rem; font-weight: 900; text-transform: uppercase; font-style: italic;">
              {{ shop.name }}
            </span>
          {%- endif -%}
        </a>
      </div>

      <div class="nav-group-{{ section.id }}" style="justify-content: flex-end;">
        <nav class="flex items-center" style="gap: {{ section.settings.gap_links }}px;">
          {%- for link in section.settings.menu_right.links -%}
            <a href="{{ link.url }}" class="header-nav-link-{{ section.id }}">
              {{ link.title }}
            </a>
          {%- endfor -%}
        </nav>

        <a href="{{ routes.cart_url }}" class="relative flex items-center ml-4">
          <svg
            width="{{ section.settings.cart_size }}"
            height="{{ section.settings.cart_size }}"
            viewBox="0 0 24 24"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path d="M7 18c-1.1 0-1.99.9-1.99 2S5.9 22 7 22s2-.9 2-2-.9-2-2-2zM1 2v2h2l3.6 7.59-1.35 2.45c-.16.28-.25.61-.25.96 0 1.1.9 2 2 2h12v-2H7.42c-.14 0-.25-.11-.25-.25l.03-.12.9-1.63h7.45c.75 0 1.41-.41 1.75-1.03l3.58-6.49c.08-.14.12-.31.12-.48 0-.55-.45-1-1-1H5.21l-.94-2H1zm16 16c-1.1 0-1.99.9-1.99 2s.89 2 1.99 2 2-.9 2-2-.9-2-2-2z" fill="{{ section.settings.cart_color }}"/>
          </svg>
          {%- if cart.item_count > 0 -%}
            <span style="position: absolute; top: -8px; right: -8px; background: {{ section.settings.text_color }}; color: {{ section.settings.bg_color }}; font-size: 10px; font-weight: bold; border-radius: 50%; width: 16px; height: 16px; display: flex; align-items: center; justify-content: center;">
              {{ cart.item_count }}
            </span>
          {%- endif -%}
        </a>
      </div>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Custom Split Header Pro",
  "settings": [
    { "type": "header", "content": "Estructura y Comportamiento" },
    {
      "type": "select",
      "id": "sticky_header",
      "label": "Header Pegajoso",
      "options": [
        { "value": "sticky", "label": "Activado" },
        { "value": "relative", "label": "Desactivado" }
      ],
      "default": "sticky"
    },
    {
      "type": "range",
      "id": "header_min_height",
      "min": 40,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Altura mínima del Header",
      "default": 80
    },
    {
      "type": "select",
      "id": "vertical_alignment",
      "label": "Alineación Vertical (Todo)",
      "options": [
        { "value": "start", "label": "Arriba" },
        { "value": "center", "label": "Centro" },
        { "value": "end", "label": "Abajo" }
      ],
      "default": "center"
    },
    { "type": "header", "content": "Logotipo" },
    { "type": "image_picker", "id": "logo", "label": "Imagen del Logo" },
    {
      "type": "range",
      "id": "logo_width",
      "min": 30,
      "max": 400,
      "step": 5,
      "unit": "px",
      "label": "Ancho del Logo",
      "default": 120
    },
    { "type": "header", "content": "Navegación" },
    { "type": "link_list", "id": "menu_left", "label": "Menú Izquierdo" },
    { "type": "link_list", "id": "menu_right", "label": "Menú Derecho" },
    {
      "type": "range",
      "id": "gap_links",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Espacio entre enlaces",
      "default": 30
    },
    { "type": "header", "content": "Estilos Visuales" },
    { "type": "color", "id": "bg_color", "label": "Fondo", "default": "#000000" },
    { "type": "color", "id": "text_color", "label": "Letras", "default": "#ffffff" },
    { "type": "font_picker", "id": "font_family", "label": "Tipografía", "default": "assistant_n4" },
    {
      "type": "range",
      "id": "font_size",
      "min": 8,
      "max": 40,
      "step": 1,
      "unit": "px",
      "label": "Tamaño Letra",
      "default": 14
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Grosor",
      "options": [
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Normal" },
        { "value": "700", "label": "Bold" },
        { "value": "900", "label": "Black" }
      ],
      "default": "700"
    },
    {
      "type": "select",
      "id": "text_transform",
      "label": "Transformación",
      "options": [
        { "value": "none", "label": "Normal" },
        { "value": "uppercase", "label": "MAYÚSCULAS" }
      ],
      "default": "uppercase"
    },
    { "type": "header", "content": "Carrito" },
    { "type": "color", "id": "cart_color", "label": "Color Icono", "default": "#ffffff" },
    {
      "type": "range",
      "id": "cart_size",
      "min": 10,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Tamaño Icono",
      "default": 24
    },
    { "type": "header", "content": "Padding" },
    {
      "type": "range",
      "id": "padding_vertical",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Espacio Arriba/Abajo",
      "default": 20
    }
  ],
  "presets": [{ "name": "Custom Split Header Pro" }]
}
{% endschema %}
