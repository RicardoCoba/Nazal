{%- style -%}
  /* Configuración del Contenedor Principal */
  .custom-header-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_vertical }}px 0;
    position: {{ section.settings.sticky_header }};
    top: 0;
    z-index: 1000;
    width: 100%;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }

  /* Grid Principal de 3 Columnas */
  .header-grid-{{ section.id }} {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: {{ section.settings.vertical_alignment }};
    min-height: {{ section.settings.header_min_height }}px;
    gap: 20px;
  }

  /* Lógica de Menús con Anchos Iguales */
  .nav-group-{{ section.id }} {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: 1fr;
    gap: {{ section.settings.gap_links }}px;
    width: 100%;
  }

  .header-nav-link-{{ section.id }} {
    color: {{ section.settings.text_color }} !important;
    font-size: {{ section.settings.font_size }}px;
    font-weight: {{ section.settings.font_weight }};
    text-transform: {{ section.settings.text_transform }};
    font-style: {{ section.settings.font_style }};
    text-decoration: none;
    white-space: nowrap;
    display: flex;
    justify-content: center;
    align-items: center;
    text-align: center;
    transition: all 0.3s ease;
    padding: 5px 0;
  }

  .header-nav-link-{{ section.id }}:hover {
    opacity: 0.5;
  }

  /* Fuente Personalizada */
  {{ section.settings.font_family | font_face }}
  .font-header-{{ section.id }} {
    font-family: {{ section.settings.font_family.family }}, {{ section.settings.font_family.fallback_families }};
  }

  /* Contenedor Derecha */
  .right-side-{{ section.id }} {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 30px;
  }

  /* Estilo para el Badge del Carrito */
  .cart-count-{{ section.id }} {
    position: absolute;
    top: -8px;
    right: -8px;
    background: {{ section.settings.cart_color }};
    color: {{ section.settings.bg_color }};
    font-size: 9px;
    font-weight: 900;
    border-radius: 50%;
    width: 16px;
    height: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid {{ section.settings.bg_color }};
  }

  @media screen and (max-width: 768px) {
    .nav-group-{{ section.id }} {
      display: none;
    }
  }
{%- endstyle -%}

<header class="custom-header-{{ section.id }} font-header-{{ section.id }}">
  <div class="container mx-auto px-6 lg:px-12">
    <div class="header-grid-{{ section.id }}">
      <nav class="nav-group-{{ section.id }}">
        {%- for link in section.settings.menu_left.links -%}
          <a href="{{ link.url }}" class="header-nav-link-{{ section.id }}">
            {{ link.title }}
          </a>
        {%- endfor -%}
      </nav>

      <div class="flex justify-center items-center">
        <a href="{{ routes.root_url }}" class="flex items-center">
          {%- if section.settings.logo != blank -%}
            <img
              src="{{ section.settings.logo | image_url: width: 600 }}"
              alt="{{ shop.name }}"
              style="width: {{ section.settings.logo_width }}px; height: auto; display: block;"
            >
          {%- else -%}
            <span style="color: {{ section.settings.text_color }}; font-size: 1.6rem; font-weight: 900; text-transform: uppercase; font-style: italic; letter-spacing: -1px;">
              {{ shop.name }}
            </span>
          {%- endif -%}
        </a>
      </div>

      <div class="right-side-{{ section.id }}">
        <nav class="nav-group-{{ section.id }}">
          {%- for link in section.settings.menu_right.links -%}
            <a href="{{ link.url }}" class="header-nav-link-{{ section.id }}">
              {{ link.title }}
            </a>
          {%- endfor -%}
        </nav>

        <a href="{{ routes.cart_url }}" class="relative flex items-center shrink-0">
          <svg
            width="{{ section.settings.cart_size }}"
            height="{{ section.settings.cart_size }}"
            viewBox="0 0 24 24"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M16 8V7C16 4.79086 14.2091 3 12 3C9.79086 3 8 4.79086 8 7V8H5V21H19V8H16ZM10 7C10 5.89543 10.8954 5 12 5C13.1046 5 14 5.89543 14 7V8H10V7ZM7 10H9V12H7V10ZM15 10H17V12H15V10Z"
              stroke="{{ section.settings.cart_color }}"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>

          {%- if cart.item_count > 0 -%}
            <span class="cart-count-{{ section.id }}">
              {{ cart.item_count }}
            </span>
          {%- endif -%}
        </a>
      </div>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Custom Split Header Pro",
  "settings": [
    { "type": "header", "content": "Comportamiento" },
    {
      "type": "select",
      "id": "sticky_header",
      "label": "Header Pegajoso",
      "options": [
        { "value": "sticky", "label": "Activado" },
        { "value": "relative", "label": "Desactivado" }
      ],
      "default": "sticky"
    },
    {
      "type": "range",
      "id": "header_min_height",
      "min": 40,
      "max": 250,
      "step": 5,
      "unit": "px",
      "label": "Altura mínima",
      "default": 90
    },
    {
      "type": "select",
      "id": "vertical_alignment",
      "label": "Alineación Vertical",
      "options": [
        { "value": "start", "label": "Arriba" },
        { "value": "center", "label": "Centro" },
        { "value": "end", "label": "Abajo" }
      ],
      "default": "center"
    },
    { "type": "header", "content": "Logotipo" },
    { "type": "image_picker", "id": "logo", "label": "Imagen del Logo" },
    {
      "type": "range",
      "id": "logo_width",
      "min": 30,
      "max": 400,
      "step": 5,
      "unit": "px",
      "label": "Ancho del Logo",
      "default": 130
    },
    { "type": "header", "content": "Menús (Divididos)" },
    { "type": "link_list", "id": "menu_left", "label": "Menú Izquierdo" },
    { "type": "link_list", "id": "menu_right", "label": "Menú Derecho" },
    {
      "type": "range",
      "id": "gap_links",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Espacio entre enlaces",
      "default": 20
    },
    { "type": "header", "content": "Estilos de Texto" },
    { "type": "color", "id": "bg_color", "label": "Fondo", "default": "#000000" },
    { "type": "color", "id": "text_color", "label": "Letras", "default": "#ffffff" },
    { "type": "font_picker", "id": "font_family", "label": "Tipografía", "default": "assistant_n4" },
    {
      "type": "range",
      "id": "font_size",
      "min": 8,
      "max": 40,
      "step": 1,
      "unit": "px",
      "label": "Tamaño Letra",
      "default": 13
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Grosor",
      "options": [
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Normal" },
        { "value": "700", "label": "Bold" },
        { "value": "900", "label": "Black" }
      ],
      "default": "700"
    },
    {
      "type": "select",
      "id": "text_transform",
      "label": "Transformación",
      "options": [
        { "value": "none", "label": "Normal" },
        { "value": "uppercase", "label": "MAYÚSCULAS" }
      ],
      "default": "uppercase"
    },
    {
      "type": "select",
      "id": "font_style",
      "label": "Estilo",
      "options": [
        { "value": "normal", "label": "Normal" },
        { "value": "italic", "label": "Itálica" }
      ],
      "default": "normal"
    },
    { "type": "header", "content": "Carrito (Bolsa)" },
    { "type": "color", "id": "cart_color", "label": "Color de Bordes", "default": "#ffffff" },
    {
      "type": "range",
      "id": "cart_size",
      "min": 10,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Tamaño Icono",
      "default": 22
    },
    { "type": "header", "content": "Espaciado" },
    {
      "type": "range",
      "id": "padding_vertical",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding Superior/Inferior",
      "default": 25
    }
  ],
  "presets": [{ "name": "Custom Split Header Pro" }]
}
{% endschema %}
