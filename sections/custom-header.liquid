{%- style -%}
  .custom-header-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_vertical }}px 0;
    position: {{ section.settings.sticky_header }};
    top: 0;
    z-index: 1000;
    width: 100%;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }

  .header-grid-{{ section.id }} {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: {{ section.settings.vertical_alignment }};
    min-height: {{ section.settings.header_min_height }}px;
  }

  .nav-group-{{ section.id }} {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: 1fr;
    gap: {{ section.settings.gap_links }}px;
    width: 100%;
  }

  .header-nav-link-{{ section.id }} {
    color: {{ section.settings.text_color }} !important;
    font-size: {{ section.settings.font_size }}px;
    font-weight: {{ section.settings.font_weight }};
    text-transform: {{ section.settings.text_transform }};
    text-decoration: none;
    display: flex;
    justify-content: center;
    align-items: center;
    transition: opacity 0.3s ease;
  }

  /* Lógica para tu Icono SVG Personalizado */
  .custom-cart-icon-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    width: {{ section.settings.cart_width }}px;
    height: {{ section.settings.cart_width | times: 1.35 }}px; /* Mantiene proporción 20:27 */
    background-color: {{ section.settings.cart_color }};

    /* Usamos tu SVG como máscara para que cambie de color */
    -webkit-mask-image: url("data:image/svg+xml;utf8,<svg width='20' height='27' viewBox='0 0 20 27' fill='none' xmlns='http://www.w3.org/2000/svg'><rect width='20' height='27' fill='black'/></svg>");
    mask-image: url("data:image/svg+xml;utf8,<svg width='20' height='27' viewBox='0 0 20 27' fill='none' xmlns='http://www.w3.org/2000/svg'><rect width='20' height='27' fill='black'/></svg>");

    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    mask-size: contain;
    -webkit-mask-size: contain;
  }

  {{ section.settings.font_family | font_face }}
  .font-header-{{ section.id }} {
    font-family: {{ section.settings.font_family.family }}, {{ section.settings.font_family.fallback_families }};
  }

  @media screen and (max-width: 768px) {
    .nav-group-{{ section.id }} { display: none; }
  }
{%- endstyle -%}

<header class="custom-header-{{ section.id }} font-header-{{ section.id }}">
  <div class="container mx-auto px-6">
    <div class="header-grid-{{ section.id }}">
      <nav class="nav-group-{{ section.id }}">
        {%- for link in section.settings.menu_left.links -%}
          <a href="{{ link.url }}" class="header-nav-link-{{ section.id }}">{{ link.title }}</a>
        {%- endfor -%}
      </nav>

      <div class="flex justify-center items-center">
        <a href="{{ routes.root_url }}">
          {%- if section.settings.logo != blank -%}
            <img
              src="{{ section.settings.logo | image_url: width: 400 }}"
              style="width: {{ section.settings.logo_width }}px; height: auto;"
            >
          {%- else -%}
            <span style="color: {{ section.settings.text_color }}; font-size: 1.5rem; font-weight: 900;">
              {{- shop.name -}}
            </span>
          {%- endif -%}
        </a>
      </div>

      <div class="flex items-center justify-end gap-8">
        <nav class="nav-group-{{ section.id }}">
          {%- for link in section.settings.menu_right.links -%}
            <a href="{{ link.url }}" class="header-nav-link-{{ section.id }}">{{ link.title }}</a>
          {%- endfor -%}
        </nav>

        <a href="{{ routes.cart_url }}" class="relative flex items-center">
          <div class="custom-cart-icon-wrapper"></div>

          {%- if cart.item_count > 0 -%}
            <span style="position: absolute; top: -5px; right: -10px; background: {{ section.settings.text_color }}; color: {{ section.settings.bg_color }}; font-size: 9px; font-weight: bold; border-radius: 50%; width: 15px; height: 15px; display: flex; align-items: center; justify-content: center;">
              {{ cart.item_count }}
            </span>
          {%- endif -%}
        </a>
      </div>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Custom Header SVG Pro",
  "settings": [
    { "type": "header", "content": "Estructura" },
    {
      "type": "select",
      "id": "sticky_header",
      "label": "Sticky",
      "options": [
        { "value": "sticky", "label": "Si" },
        { "value": "relative", "label": "No" }
      ],
      "default": "sticky"
    },
    {
      "type": "range",
      "id": "header_min_height",
      "min": 40,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Altura Header",
      "default": 80
    },
    {
      "type": "select",
      "id": "vertical_alignment",
      "label": "Alineación Vertical",
      "options": [
        { "value": "start", "label": "Arriba" },
        { "value": "center", "label": "Centro" },
        { "value": "end", "label": "Abajo" }
      ],
      "default": "center"
    },
    { "type": "header", "content": "Logotipo" },
    { "type": "image_picker", "id": "logo", "label": "Logo" },
    {
      "type": "range",
      "id": "logo_width",
      "min": 50,
      "max": 300,
      "step": 5,
      "unit": "px",
      "label": "Ancho Logo",
      "default": 100
    },
    { "type": "header", "content": "Menús" },
    { "type": "link_list", "id": "menu_left", "label": "Menú Izquierdo" },
    { "type": "link_list", "id": "menu_right", "label": "Menú Derecho" },
    {
      "type": "range",
      "id": "gap_links",
      "min": 10,
      "max": 100,
      "step": 5,
      "label": "Espacio entre links",
      "default": 30
    },
    { "type": "header", "content": "Estilos" },
    { "type": "color", "id": "bg_color", "label": "Fondo", "default": "#000000" },
    { "type": "color", "id": "text_color", "label": "Texto", "default": "#ffffff" },
    { "type": "font_picker", "id": "font_family", "label": "Fuente", "default": "assistant_n4" },
    { "type": "range", "id": "font_size", "min": 10, "max": 30, "label": "Tamaño Fuente", "default": 14 },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Peso",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "700", "label": "Bold" },
        { "value": "900", "label": "Black" }
      ],
      "default": "700"
    },
    { "type": "header", "content": "Configuración del Icono" },
    { "type": "color", "id": "cart_color", "label": "Color del Icono SVG", "default": "#ffffff" },
    {
      "type": "range",
      "id": "cart_width",
      "min": 10,
      "max": 60,
      "step": 1,
      "unit": "px",
      "label": "Ancho del Icono",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "min": 5,
      "max": 50,
      "label": "Padding Superior/Inferior",
      "default": 20
    }
  ],
  "presets": [{ "name": "Custom Header SVG Pro" }]
}
{% endschema %}
