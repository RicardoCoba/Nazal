{%- style -%}
  .separator-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding: {{ section.settings.separator_height }}px 0;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: {{ section.settings.image_position }};
    overflow: hidden;
  }

  .separator-{{ section.id }} img {
    width: {{ section.settings.image_width }}px;
    height: auto;
    display: block;
    transition: transform 0.3s ease;
  }

  /* Margen opcional para que la imagen no pegue a los bordes en laterales */
  .separator-{{ section.id }} .img-container {
    padding: 0 5%;
    width: 100%;
    display: flex;
    justify-content: {{ section.settings.image_position }};
  }
{%- endstyle -%}

<div class="separator-{{ section.id }}" role="presentation">
  <div class="img-container">
    {%- if section.settings.image != blank -%}
      <img
        src="{{ section.settings.image | image_url: width: 1000 }}"
        alt="{{ section.settings.image.alt | escape }}"
        loading="lazy"
      >
    {%- else -%}
      {%- if section.settings.show_placeholder -%}
        <div
          style="width: {{ section.settings.image_width }}px; height: 2px; background: {{ section.settings.placeholder_color }}; opacity: 0.3;"
        ></div>
      {%- endif -%}
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Custom Image Separator",
  "settings": [
    {
      "type": "header",
      "content": "Ajustes del Separador"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Color de Fondo",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "separator_height",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Grosor del Separador (Padding)",
      "default": 40
    },
    {
      "type": "header",
      "content": "Imagen / Icono"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Seleccionar Imagen"
    },
    {
      "type": "range",
      "id": "image_width",
      "min": 10,
      "max": 800,
      "step": 10,
      "unit": "px",
      "label": "Ancho de la Imagen",
      "default": 100
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Posición de la Imagen",
      "options": [
        { "value": "flex-start", "label": "Izquierda" },
        { "value": "center", "label": "Centro" },
        { "value": "flex-end", "label": "Derecha" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Opciones de Respaldo"
    },
    {
      "type": "checkbox",
      "id": "show_placeholder",
      "label": "Mostrar línea si no hay imagen",
      "default": true
    },
    {
      "type": "color",
      "id": "placeholder_color",
      "label": "Color de la línea",
      "default": "#000000"
    }
  ],
  "presets": [
    {
      "name": "Custom Image Separator"
    }
  ]
}
{% endschema %}
