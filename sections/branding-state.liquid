{%- style -%}
  .brand-statement-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_v }}px 0;
    text-align: {{ section.settings.horizontal_alignment }};
  }

  .brand-logo-wrapper-{{ section.id }} {
    display: flex;
    justify-content: {% if section.settings.horizontal_alignment == 'left' %}flex-start{% elsif section.settings.horizontal_alignment == 'center' %}center{% else %}flex-end{% endif %};
    margin-bottom: {{ section.settings.logo_margin_bottom }}px;
  }

  .brand-logo-{{ section.id }} {
    width: {{ section.settings.logo_width }}px;
    height: auto;
    display: block;
  }

  .brand-text-{{ section.id }} {
    color: {{ section.settings.text_color }};
    font-size: {{ section.settings.font_size }}px;
    font-weight: {{ section.settings.font_weight }};
    text-transform: {{ section.settings.text_transform }};
    font-style: {{ section.settings.font_style }};
    line-height: 1.4;
    max-width: {{ section.settings.content_max_width }}px;
    {% if section.settings.horizontal_alignment == 'center' %}
      margin: 0 auto;
    {% elsif section.settings.horizontal_alignment == 'right' %}
      margin-left: auto;
    {% endif %}
  }

  /* Tipografía Personalizada */
  {{ section.settings.font_family | font_face }}
  .font-custom-{{ section.id }} {
    font-family: {{ section.settings.font_family.family }}, {{ section.settings.font_family.fallback_families }};
  }

  .brand-text-{{ section.id }} strong {
    font-weight: 900; /* Fuerza la negrita extra */
  }

  @media screen and (max-width: 768px) {
    .brand-text-{{ section.id }} {
      font-size: clamp(16px, 5vw, {{ section.settings.font_size }}px);
      padding: 0 20px;
    }
    .brand-logo-{{ section.id }} {
      width: {{ section.settings.logo_width | times: 0.8 }}px;
    }
  }
{%- endstyle -%}

<div class="brand-statement-{{ section.id }} font-custom-{{ section.id }}">
  <div class="container mx-auto px-6">
    {%- if section.settings.logo != blank -%}
      <div class="brand-logo-wrapper-{{ section.id }}">
        <img
          src="{{ section.settings.logo | image_url: width: 800 }}"
          class="brand-logo-{{ section.id }}"
          alt="{{ shop.name }}"
          loading="lazy"
        >
      </div>
    {%- endif -%}

    {%- if section.settings.content != blank -%}
      <div class="brand-text-{{ section.id }}">
        {{ section.settings.content }}
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Brand Statement & Logo",
  "settings": [
    { "type": "header", "content": "Ajustes de Fondo" },
    { "type": "color", "id": "bg_color", "label": "Color de Fondo", "default": "#ffffff" },
    {
      "type": "range",
      "id": "padding_v",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Espaciado Vertical",
      "default": 80
    },

    { "type": "header", "content": "Logotipo" },
    { "type": "image_picker", "id": "logo", "label": "Imagen del Logo" },
    {
      "type": "range",
      "id": "logo_width",
      "min": 30,
      "max": 600,
      "step": 10,
      "unit": "px",
      "label": "Ancho del Logo",
      "default": 150
    },
    {
      "type": "range",
      "id": "logo_margin_bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Margen inferior del Logo",
      "default": 30
    },

    { "type": "header", "content": "Texto y Tipografía" },
    {
      "type": "richtext",
      "id": "content",
      "label": "Texto (Usa Negritas aquí)",
      "default": "<p>Escribe aquí tu <strong>mensaje de marca</strong>.</p>"
    },
    { "type": "color", "id": "text_color", "label": "Color de Texto", "default": "#000000" },
    { "type": "font_picker", "id": "font_family", "label": "Tipografía", "default": "assistant_n4" },
    {
      "type": "range",
      "id": "font_size",
      "min": 12,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Tamaño de Fuente",
      "default": 24
    },
    {
      "type": "range",
      "id": "content_max_width",
      "min": 400,
      "max": 1400,
      "step": 50,
      "unit": "px",
      "label": "Ancho máximo del texto",
      "default": 800
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Grosor (Normal)",
      "options": [
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Normal" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "400"
    },
    {
      "type": "select",
      "id": "text_transform",
      "label": "Transformación",
      "options": [
        { "value": "none", "label": "Normal" },
        { "value": "uppercase", "label": "MAYÚSCULAS" }
      ],
      "default": "none"
    },
    {
      "type": "select",
      "id": "font_style",
      "label": "Estilo",
      "options": [
        { "value": "normal", "label": "Normal" },
        { "value": "italic", "label": "Itálica" }
      ],
      "default": "normal"
    },
    {
      "type": "select",
      "id": "horizontal_alignment",
      "label": "Alineación Horizontal",
      "options": [
        { "value": "left", "label": "Izquierda" },
        { "value": "center", "label": "Centro" },
        { "value": "right", "label": "Derecha" }
      ],
      "default": "center"
    }
  ],
  "presets": [{ "name": "Brand Statement & Logo" }]
}
{% endschema %}
