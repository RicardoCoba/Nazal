{%- style -%}
  .brand-statement-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_v }}px 0;
    text-align: center;
    overflow: visible;
    /* Perspectiva aumentada para un efecto 3D más dramático */
    perspective: 800px;
  }

  .brand-header-{{ section.id }} {
    max-width: {{ section.settings.content_max_width }}px;
    margin: 0 auto {{ section.settings.logo_margin_bottom }}px auto;
  }

  .brand-logo-{{ section.id }} {
    width: {{ section.settings.logo_width }}px;
    height: auto;
    margin-bottom: 20px;
    display: inline-block;
  }

  .brand-text-{{ section.id }} {
    color: {{ section.settings.text_color }};
    font-size: {{ section.settings.font_size }}px;
    font-weight: {{ section.settings.font_weight }};
    text-transform: {{ section.settings.text_transform }};
    line-height: 1.2;
  }

  .circle-wrapper-{{ section.id }} {
    display: flex;
    justify-content: center;
    margin-top: {{ section.settings.circle_margin_top }}px;
    padding: 150px 0;
    position: relative;
  }

  .circle-container-{{ section.id }} {
    position: relative;
    width: {{ section.settings.circle_size }}px;
    height: {{ section.settings.circle_size }}px;
    border: {{ section.settings.circle_border_width }}px solid {{ section.settings.circle_border_color }};
    border-radius: 50%;
    background-color: {{ section.settings.circle_bg_color }};
  }

  /* IMAGEN CENTRAL 3D INTENSIFICADA */
  .center-image-{{ section.id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    /* Estado inicial: centrado y escala normal */
    transform: translate(-50%, -50%) scale(1);
    width: {{ section.settings.inner_image_width }}%;
    z-index: 1;
    pointer-events: none;
    /* Transición más rápida para respuesta inmediata */
    transition: transform 0.1s ease-out;
    transform-style: preserve-3d;
    will-change: transform;
  }

  .center-image-{{ section.id }} img {
    width: 100%;
    height: auto;
    display: block;
    /* Sombra más pronunciada para mayor profundidad */
    filter: drop-shadow(0 40px 50px rgba(0,0,0,0.3));
  }

  /* Nodos y Beneficios */
  .clock-node-{{ section.id }} { position: absolute; width: 0; height: 0; z-index: 10; }

  .node-dot-{{ section.id }} {
    width: {{ section.settings.dot_size }}px !important;
    height: {{ section.settings.dot_size }}px !important;
    background-color: {{ section.settings.dot_color }} !important;
    border-radius: 50% !important;
    position: absolute !important;
    transform: translate(-50%, -50%) !important;
    z-index: 20 !important;
    display: block !important;
  }

  .node-content-{{ section.id }} {
    position: absolute;
    display: flex;
    flex-direction: column;
    gap: 10px;
    width: {{ section.settings.node_content_width }}px;
    align-items: {{ section.settings.content_block_align }};
    text-align: {{ section.settings.content_block_align | replace: 'flex-start', 'left' | replace: 'flex-end', 'right' }};
  }

  .node-text-{{ section.id }} {
    color: {{ section.settings.node_text_color }};
    font-size: {{ section.settings.node_font_size }}px;
    font-weight: {{ section.settings.node_font_weight }};
    line-height: 1.1;
  }

  .node-icon-{{ section.id }} img {
    width: {{ section.settings.node_icon_width }}px;
    height: auto;
    display: block;
  }

  /* Coordenadas */
  .pos-12 { top: 0%; left: 50%; }
  .pos-2  { top: 25%; left: 93.3%; }
  .pos-4  { top: 75%; left: 93.3%; }
  .pos-6  { top: 100%; left: 50%; }
  .pos-8  { top: 75%; left: 6.7%; }
  .pos-10 { top: 25%; left: 6.7%; }

  {%- assign dist = section.settings.node_distance -%}
  .pos-12 .node-content-{{ section.id }} { bottom: {{ dist }}px; left: 50%; transform: translateX(-50%); }
  .pos-2  .node-content-{{ section.id }} { left: {{ dist }}px; top: 0; transform: translateY(-50%); }
  .pos-4  .node-content-{{ section.id }} { left: {{ dist }}px; bottom: 0; transform: translateY(50%); }
  .pos-6  .node-content-{{ section.id }} { top: {{ dist }}px; left: 50%; transform: translateX(-50%); }
  .pos-8  .node-content-{{ section.id }} { right: {{ dist }}px; bottom: 0; transform: translateY(50%); }
  .pos-10 .node-content-{{ section.id }} { right: {{ dist }}px; top: 0; transform: translateY(-50%); }

  @media screen and (max-width: 768px) {
    .circle-wrapper-{{ section.id }} { transform: scale(0.65); padding: 40px 0; }
  }
{%- endstyle -%}

<div class="brand-statement-{{ section.id }}" id="Section-{{ section.id }}">
  <div class="container mx-auto px-6">
    <div
      class="brand-header-{{ section.id }}"
      style="font-family: {{ section.settings.font_family.family }}, sans-serif;"
    >
      {%- if section.settings.logo != blank -%}
        <img src="{{ section.settings.logo | image_url: width: 600 }}" class="brand-logo-{{ section.id }}" alt="Logo">
      {%- endif -%}
      {%- if section.settings.content != blank -%}
        <div class="brand-text-{{ section.id }}">{{ section.settings.content }}</div>
      {%- endif -%}
    </div>

    <div class="circle-wrapper-{{ section.id }}">
      <div class="circle-container-{{ section.id }}">
        <div class="center-image-{{ section.id }}" id="Tilt-Image-{{ section.id }}">
          {%- if section.settings.circle_image != blank -%}
            <img src="{{ section.settings.circle_image | image_url: width: 1000 }}" alt="Product">
          {%- endif -%}
        </div>

        {%- for block in section.blocks -%}
          <div class="clock-node-{{ section.id }} pos-{{ block.settings.position }}" {{ block.shopify_attributes }}>
            <div class="node-dot-{{ section.id }}">&nbsp;</div>
            <div
              class="node-content-{{ section.id }}"
              style="font-family: {{ section.settings.node_font_family.family }}, sans-serif;"
            >
              {%- if block.settings.node_text != blank -%}
                <div class="node-text-{{ section.id }}">{{ block.settings.node_text | escape }}</div>
              {%- endif -%}
              {%- if block.settings.node_image != blank -%}
                <div class="node-icon-{{ section.id }}">
                  <img src="{{ block.settings.node_image | image_url: width: 300 }}" alt="Icon">
                </div>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const container = document.getElementById('Section-{{ section.id }}');
    const image = document.getElementById('Tilt-Image-{{ section.id }}');
    if (!container || !image) return;

    container.addEventListener('mousemove', (e) => {
      const rect = container.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;

      const centerX = rect.width / 2;
      const centerY = rect.height / 2;

      // --- AJUSTES DE INTENSIDAD ---
      // Aumentamos el multiplicador a 25 (antes 12) para que rote más.
      const rotateX = ((y - centerY) / centerY) * -25;
      const rotateY = ((x - centerX) / centerX) * 25;

      // Añadimos un ligero escalado (scale(1.05)) al mover el mouse
      image.style.transform = `translate(-50%, -50%) scale(1.05) rotateX(${rotateX}deg) rotateY(${rotateY}deg)`;
    });

    container.addEventListener('mouseleave', () => {
      image.style.transition = 'transform 0.6s ease';
      // Reseteamos rotación y escala a normal
      image.style.transform = `translate(-50%, -50%) scale(1) rotateX(0deg) rotateY(0deg)`;
      setTimeout(() => {
        image.style.transition = 'transform 0.1s ease-out';
      }, 600);
    });
  });
</script>

{% schema %}
{
  "name": "Brand Circular Feature",
  "settings": [
    { "type": "header", "content": "Sección" },
    { "type": "color", "id": "bg_color", "label": "Fondo Sección", "default": "#ffffff" },
    {
      "type": "range",
      "id": "padding_v",
      "min": 0,
      "max": 400,
      "step": 10,
      "unit": "px",
      "label": "Padding Vertical",
      "default": 100
    },
    { "type": "header", "content": "Logo y Texto Superior" },
    { "type": "image_picker", "id": "logo", "label": "Logo" },
    {
      "type": "range",
      "id": "logo_width",
      "min": 50,
      "max": 400,
      "step": 10,
      "unit": "px",
      "label": "Ancho Logo",
      "default": 150
    },
    { "type": "richtext", "id": "content", "label": "Texto Principal" },
    { "type": "color", "id": "text_color", "label": "Color Texto", "default": "#000000" },
    { "type": "font_picker", "id": "font_family", "label": "Fuente Principal", "default": "assistant_n4" },
    {
      "type": "range",
      "id": "font_size",
      "min": 10,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Tamaño Fuente",
      "default": 24
    },
    {
      "type": "range",
      "id": "content_max_width",
      "min": 300,
      "max": 1200,
      "step": 50,
      "unit": "px",
      "label": "Ancho Máximo",
      "default": 600
    },
    {
      "type": "range",
      "id": "logo_margin_bottom",
      "min": 0,
      "max": 200,
      "step": 10,
      "unit": "px",
      "label": "Margen abajo cabecera",
      "default": 60
    },
    { "type": "header", "content": "Círculo de Producto" },
    { "type": "image_picker", "id": "circle_image", "label": "Imagen del Producto (Centro)" },
    {
      "type": "range",
      "id": "circle_size",
      "min": 200,
      "max": 800,
      "step": 20,
      "unit": "px",
      "label": "Diámetro Círculo",
      "default": 400
    },
    { "type": "color", "id": "circle_border_color", "label": "Color Línea Círculo", "default": "#e0e0e0" },
    {
      "type": "range",
      "id": "circle_border_width",
      "min": 1,
      "max": 10,
      "step": 1,
      "unit": "px",
      "label": "Grosor Línea",
      "default": 1
    },
    { "type": "color", "id": "circle_bg_color", "label": "Fondo Círculo", "default": "transparent" },
    {
      "type": "range",
      "id": "inner_image_width",
      "min": 10,
      "max": 150,
      "step": 5,
      "unit": "%",
      "label": "Escala Imagen Producto",
      "default": 80
    },
    {
      "type": "range",
      "id": "circle_margin_top",
      "min": 0,
      "max": 200,
      "step": 10,
      "unit": "px",
      "label": "Margen Superior",
      "default": 40
    },
    { "type": "header", "content": "Estilo de los Beneficios" },
    {
      "type": "range",
      "id": "node_distance",
      "min": 10,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Separación Texto",
      "default": 30
    },
    {
      "type": "select",
      "id": "content_block_align",
      "label": "Alineación",
      "options": [
        { "value": "flex-start", "label": "Izquierda" },
        { "value": "center", "label": "Centro" },
        { "value": "flex-end", "label": "Derecha" }
      ],
      "default": "center"
    },
    { "type": "color", "id": "dot_color", "label": "Color Punto", "default": "#000000" },
    {
      "type": "range",
      "id": "dot_size",
      "min": 4,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Tamaño Punto",
      "default": 12
    },
    { "type": "color", "id": "node_text_color", "label": "Color Texto Beneficio", "default": "#000000" },
    { "type": "font_picker", "id": "node_font_family", "label": "Fuente Beneficios", "default": "assistant_n4" },
    {
      "type": "range",
      "id": "node_font_size",
      "min": 8,
      "max": 50,
      "step": 1,
      "unit": "px",
      "label": "Tamaño Fuente",
      "default": 14
