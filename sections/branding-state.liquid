{%- style -%}
  .brand-statement-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_v }}px 0;
    text-align: {{ section.settings.horizontal_alignment }};
  }

  .brand-logo-wrapper-{{ section.id }} {
    display: flex;
    justify-content: {% if section.settings.horizontal_alignment == 'left' %}flex-start{% elsif section.settings.horizontal_alignment == 'center' %}center{% else %}flex-end{% endif %};
    margin-bottom: {{ section.settings.logo_margin_bottom }}px;
  }

  .brand-logo-{{ section.id }} {
    width: {{ section.settings.logo_width }}px;
    height: auto;
  }

  .brand-text-{{ section.id }} {
    color: {{ section.settings.text_color }};
    font-size: {{ section.settings.font_size }}px;
    font-weight: {{ section.settings.font_weight }};
    text-transform: {{ section.settings.text_transform }};
    font-style: {{ section.settings.font_style }};
    line-height: 1.4;
    max-width: {{ section.settings.content_max_width }}px;
    {% if section.settings.horizontal_alignment == 'center' %}
      margin: 0 auto;
    {% elsif section.settings.horizontal_alignment == 'right' %}
      margin-left: auto;
    {% endif %}
  }

  /* Estilos del Círculo Decorativo */
  .circle-container-{{ section.id }} {
    display: flex;
    justify-content: {% if section.settings.horizontal_alignment == 'left' %}flex-start{% elsif section.settings.horizontal_alignment == 'center' %}center{% else %}flex-end{% endif %};
    margin-top: {{ section.settings.circle_margin_top }}px;
  }

  .brand-circle-{{ section.id }} {
    width: {{ section.settings.circle_size }}px;
    height: {{ section.settings.circle_size }}px;
    border: {{ section.settings.circle_border_width }}px solid {{ section.settings.circle_border_color }};
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    position: relative;
    background-color: {{ section.settings.circle_bg_color }};
  }

  .brand-circle-{{ section.id }} img {
    width: {{ section.settings.inner_image_width }}%;
    height: auto;
    object-fit: contain;
  }

  /* Tipografía */
  {{ section.settings.font_family | font_face }}
  .font-custom-{{ section.id }} {
    font-family: {{ section.settings.font_family.family }}, {{ section.settings.font_family.fallback_families }};
  }

  @media screen and (max-width: 768px) {
    .brand-circle-{{ section.id }} {
      width: {{ section.settings.circle_size | times: 0.7 }}px;
      height: {{ section.settings.circle_size | times: 0.7 }}px;
    }
  }
{%- endstyle -%}

<div class="brand-statement-{{ section.id }} font-custom-{{ section.id }}">
  <div class="container mx-auto px-6">
    {%- comment -%} Logo Superior {%- endcomment -%}
    {%- if section.settings.logo != blank -%}
      <div class="brand-logo-wrapper-{{ section.id }}">
        <img
          src="{{ section.settings.logo | image_url: width: 800 }}"
          class="brand-logo-{{ section.id }}"
          alt="{{ shop.name }}"
          loading="lazy"
        >
      </div>
    {%- endif -%}

    {%- comment -%} Texto Principal {%- endcomment -%}
    {%- if section.settings.content != blank -%}
      <div class="brand-text-{{ section.id }}">
        {{ section.settings.content }}
      </div>
    {%- endif -%}

    {%- comment -%} Círculo con Imagen {%- endcomment -%}
    {%- if section.settings.show_circle -%}
      <div class="circle-container-{{ section.id }}">
        <div class="brand-circle-{{ section.id }}">
          {%- if section.settings.circle_image != blank -%}
            <img src="{{ section.settings.circle_image | image_url: width: 400 }}" alt="Circle Image" loading="lazy">
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Brand Statement & Circle",
  "settings": [
    { "type": "header", "content": "Ajustes Generales" },
    { "type": "color", "id": "bg_color", "label": "Color de Fondo Sección", "default": "#ffffff" },
    {
      "type": "range",
      "id": "padding_v",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Espaciado Vertical",
      "default": 80
    },
    {
      "type": "select",
      "id": "horizontal_alignment",
      "label": "Alineación Global",
      "options": [
        { "value": "left", "label": "Izquierda" },
        { "value": "center", "label": "Centro" },
        { "value": "right", "label": "Derecha" }
      ],
      "default": "center"
    },

    { "type": "header", "content": "Logotipo Superior" },
    { "type": "image_picker", "id": "logo", "label": "Logo" },
    {
      "type": "range",
      "id": "logo_width",
      "min": 30,
      "max": 600,
      "step": 10,
      "unit": "px",
      "label": "Ancho",
      "default": 150
    },
    {
      "type": "range",
      "id": "logo_margin_bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Margen Inferior",
      "default": 30
    },

    { "type": "header", "content": "Texto Principal" },
    {
      "type": "richtext",
      "id": "content",
      "label": "Contenido",
      "default": "<p>Escribe tu <strong>mensaje</strong> aquí.</p>"
    },
    { "type": "color", "id": "text_color", "label": "Color", "default": "#000000" },
    { "type": "font_picker", "id": "font_family", "label": "Fuente", "default": "assistant_n4" },
    {
      "type": "range",
      "id": "font_size",
      "min": 12,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Tamaño",
      "default": 24
    },
    {
      "type": "range",
      "id": "content_max_width",
      "min": 400,
      "max": 1400,
      "step": 50,
      "unit": "px",
      "label": "Ancho Máximo del Texto",
      "default": 800
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Grosor",
      "options": [
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Normal" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "400"
    },
    {
      "type": "select",
      "id": "text_transform",
      "label": "Mayúsculas",
      "options": [
        { "value": "none", "label": "No" },
        { "value": "uppercase", "label": "Sí" }
      ],
      "default": "none"
    },
    {
      "type": "select",
      "id": "font_style",
      "label": "Estilo",
      "options": [
        { "value": "normal", "label": "Normal" },
        { "value": "italic", "label": "Itálica" }
      ],
      "default": "normal"
    },

    { "type": "header", "content": "Círculo Decorativo" },
    { "type": "checkbox", "id": "show_circle", "label": "Mostrar Círculo", "default": true },
    { "type": "color", "id": "circle_border_color", "label": "Color del Borde", "default": "#000000" },
    {
      "type": "range",
      "id": "circle_border_width",
      "min": 1,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Grosor del Borde",
      "default": 2
    },
    { "type": "color", "id": "circle_bg_color", "label": "Fondo del Círculo (Relleno)", "default": "transparent" },
    {
      "type": "range",
      "id": "circle_size",
      "min": 50,
      "max": 400,
      "step": 10,
      "unit": "px",
      "label": "Tamaño del Círculo",
      "default": 120
    },
    {
      "type": "range",
      "id": "circle_margin_top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Margen Superior",
      "default": 40
    },
    { "type": "image_picker", "id": "circle_image", "label": "Imagen dentro del círculo" },
    {
      "type": "range",
      "id": "inner_image_width",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Tamaño imagen interna",
      "default": 60
    }
  ],
  "presets": [{ "name": "Brand Statement & Circle" }]
}
{% endschema %}
