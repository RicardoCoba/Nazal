{%- style -%}
  .brand-statement-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_v }}px 0;
    text-align: center;
    overflow: visible !important;
  }

  .circle-wrapper-{{ section.id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    margin: {{ section.settings.circle_margin_top }}px auto;
    padding: 160px 0;
    position: relative;
  }

  .circle-container-{{ section.id }} {
    position: relative;
    width: {{ section.settings.circle_size }}px;
    height: {{ section.settings.circle_size }}px;
    border: {{ section.settings.circle_border_width }}px solid {{ section.settings.circle_border_color }};
    border-radius: 50%;
    overflow: visible !important;
  }

  .clock-node-{{ section.id }} {
    position: absolute;
    width: 1px;
    height: 1px;
    z-index: 100;
  }

  /* Contenedor del Punto (Ya no estará vacío gracias al SVG) */
  .node-dot-{{ section.id }} {
    width: {{ section.settings.dot_size }}px !important;
    height: {{ section.settings.dot_size }}px !important;
    position: absolute !important;
    top: 50% !important;
    left: 50% !important;
    transform: translate(-50%, -50%) !important;
    display: flex !important; /* Para centrar el SVG */
    align-items: center;
    justify-content: center;
  }

  .node-dot-{{ section.id }} svg {
    width: 100%;
    height: 100%;
    fill: {{ section.settings.dot_color }}; /* Controlamos el color desde aquí */
    display: block;
  }

  .node-content-{{ section.id }} {
    position: absolute;
    display: flex;
    flex-direction: column;
    gap: 10px;
    width: {{ section.settings.node_content_width }}px;
    align-items: {{ section.settings.content_block_align }};
    text-align: {{ section.settings.content_block_align | replace: 'flex-start', 'left' | replace: 'flex-end', 'right' }};
  }

  /* Coordenadas */
  .pos-12 { top: 0%; left: 50%; }
  .pos-2  { top: 25%; left: 93.3%; }
  .pos-4  { top: 75%; left: 93.3%; }
  .pos-6  { top: 100%; left: 50%; }
  .pos-8  { top: 75%; left: 6.7%; }
  .pos-10 { top: 25%; left: 6.7%; }

  {%- assign gap = section.settings.node_distance -%}
  .pos-12 .node-content-{{ section.id }} { bottom: {{ gap }}px; left: 50%; transform: translateX(-50%); }
  .pos-2  .node-content-{{ section.id }} { left: {{ gap }}px; top: 0; transform: translateY(-50%); }
  .pos-4  .node-content-{{ section.id }} { left: {{ gap }}px; bottom: 0; transform: translateY(50%); }
  .pos-6  .node-content-{{ section.id }} { top: {{ gap }}px; left: 50%; transform: translateX(-50%); }
  .pos-8  .node-content-{{ section.id }} { right: {{ gap }}px; bottom: 0; transform: translateY(50%); }
  .pos-10 .node-content-{{ section.id }} { right: {{ gap }}px; top: 0; transform: translateY(-50%); }

  @media screen and (max-width: 768px) {
    .circle-wrapper-{{ section.id }} { transform: scale(0.6); }
  }
{%- endstyle -%}

<div class="brand-statement-{{ section.id }}">
  <div class="circle-wrapper-{{ section.id }}">
    <div class="circle-container-{{ section.id }}">
      {%- if section.settings.circle_image != blank -%}
        <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: {{ section.settings.inner_image_width }}%; z-index: 10;">
          <img src="{{ section.settings.circle_image | image_url: width: 800 }}" style="width: 100%; height: auto;">
        </div>
      {%- endif -%}

      {%- for block in section.blocks -%}
        <div class="clock-node-{{ section.id }} pos-{{ block.settings.position }}" {{ block.shopify_attributes }}>
          <div class="node-dot-{{ section.id }}">
            <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
              <circle cx="50" cy="50" r="50" />
            </svg>
          </div>

          <div class="node-content-{{ section.id }}">
            {%- if block.settings.node_text != blank -%}
              <div
                class="node-text-{{ section.id }}"
                style="font-family: {{ section.settings.node_font_family.family }}, sans-serif; color: {{ section.settings.node_text_color }}; font-size: {{ section.settings.node_font_size }}px; font-weight: {{ section.settings.node_font_weight }}; text-transform: {{ section.settings.node_text_transform }};"
              >
                {{ block.settings.node_text | escape }}
              </div>
            {%- endif -%}
            {%- if block.settings.node_image != blank -%}
              <div class="node-icon-{{ section.id }}">
                <img
                  src="{{ block.settings.node_image | image_url: width: 300 }}"
                  style="width: {{ section.settings.node_icon_width }}px; height: auto;"
                >
              </div>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Brand Circular Feature",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Fondo", "default": "#ffffff" },
    {
      "type": "range",
      "id": "padding_v",
      "min": 0,
      "max": 400,
      "step": 10,
      "unit": "px",
      "label": "Padding Vertical",
      "default": 100
    },
    { "type": "image_picker", "id": "circle_image", "label": "Imagen Centro" },
    {
      "type": "range",
      "id": "circle_size",
      "min": 200,
      "max": 800,
      "step": 10,
      "unit": "px",
      "label": "Diámetro Círculo",
      "default": 450
    },
    { "type": "color", "id": "circle_border_color", "label": "Color Línea", "default": "#000000" },
    { "type": "range", "id": "circle_border_width", "min": 1, "max": 10, "label": "Grosor Línea", "default": 1 },
    { "type": "color", "id": "dot_color", "label": "Color Punto", "default": "#000000" },
    { "type": "range", "id": "dot_size", "min": 5, "max": 50, "label": "Tamaño Punto", "default": 15 },
    {
      "type": "range",
      "id": "inner_image_width",
      "min": 10,
      "max": 150,
      "unit": "%",
      "label": "Escala Imagen",
      "default": 80
    },
    { "type": "range", "id": "circle_margin_top", "min": 0, "max": 200, "label": "Margen Superior", "default": 40 },
    { "type": "range", "id": "node_distance", "min": 10, "max": 250, "label": "Distancia Texto", "default": 60 },
    {
      "type": "select",
      "id": "content_block_align",
      "label": "Alineación",
      "options": [
        { "value": "flex-start", "label": "Izq" },
        { "value": "center", "label": "Centro" },
        { "value": "flex-end", "label": "Der" }
      ],
      "default": "center"
    },
    { "type": "color", "id": "node_text_color", "label": "Color Texto", "default": "#000000" },
    { "type": "font_picker", "id": "node_font_family", "label": "Fuente", "default": "assistant_n4" },
    { "type": "range", "id": "node_font_size", "min": 10, "max": 40, "label": "Letra", "default": 14 },
    {
      "type": "select",
      "id": "node_font_weight",
      "label": "Peso",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "700"
    },
    {
      "type": "select",
      "id": "node_text_transform",
      "label": "Mayúsculas",
      "options": [
        { "value": "none", "label": "No" },
        { "value": "uppercase", "label": "Sí" }
      ],
      "default": "uppercase"
    },
    { "type": "range", "id": "node_content_width", "min": 50, "max": 500, "label": "Ancho Bloque", "default": 180 },
    { "type": "range", "id": "node_icon_width", "min": 10, "max": 200, "label": "Icono", "default": 40 }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Beneficio",
      "settings": [
        {
          "type": "select",
          "id": "position",
          "label": "Hora",
          "options": [
            { "value": "12", "label": "12:00" },
            { "value": "2", "label": "02:00" },
            { "value": "4", "label": "04:00" },
            { "value": "6", "label": "06:00" },
            { "value": "8", "label": "08:00" },
            { "value": "10", "label": "10:00" }
          ],
          "default": "12"
        },
        { "type": "text", "id": "node_text", "label": "Texto" },
        { "type": "image_picker", "id": "node_image", "label": "Icono" }
      ]
    }
  ],
  "presets": [{ "name": "Brand Circular Feature" }]
}
{% endschema %}
