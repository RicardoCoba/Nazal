{%- style -%}
  .brand-statement-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_v }}px 0;
    text-align: {{ section.settings.horizontal_alignment }};
    overflow: visible; /* Permitir que los círculos sobresalgan si es necesario */
  }

  /* Contenedor del sistema solar/reloj */
  .clock-system-{{ section.id }} {
    position: relative;
    width: {{ section.settings.circle_size }}px;
    height: {{ section.settings.circle_size }}px;
    margin: {{ section.settings.circle_margin_top }}px auto 0;
    {% if section.settings.horizontal_alignment == 'left' %} margin-left: 0; {% elsif section.settings.horizontal_alignment == 'right' %} margin-right: 0; {% endif %}
  }

  /* Círculo Central */
  .brand-circle-{{ section.id }} {
    width: 100%;
    height: 100%;
    border: {{ section.settings.circle_border_width }}px solid {{ section.settings.circle_border_color }};
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background-color: {{ section.settings.circle_bg_color }};
    position: relative;
    z-index: 2;
  }

  .brand-circle-{{ section.id }} img {
    width: {{ section.settings.inner_image_width }}%;
    height: auto;
    object-fit: contain;
  }

  /* Puntos/Nodos del Reloj */
  .clock-node-{{ section.id }} {
    position: absolute;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    transform: translate(-50%, -50%);
  }

  .node-dot-{{ section.id }} {
    width: {{ section.settings.dot_size }}px;
    height: {{ section.settings.dot_size }}px;
    background-color: {{ section.settings.dot_color }};
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .node-dot-{{ section.id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .node-text-{{ section.id }} {
    position: absolute;
    width: 180px; /* Ancho para el texto alrededor */
    color: {{ section.settings.node_text_color }};
    font-size: {{ section.settings.node_font_size }}px;
    font-weight: {{ section.settings.node_font_weight }};
    text-transform: {{ section.settings.node_text_transform }};
    font-style: {{ section.settings.node_font_style }};
    line-height: 1.1;
    pointer-events: none;
  }

  /* Posiciones exactas (Reloj) */
  .pos-12 { top: 0%; left: 50%; }
  .pos-2  { top: 25%; left: 93.3%; }
  .pos-4  { top: 75%; left: 93.3%; }
  .pos-6  { top: 100%; left: 50%; }
  .pos-8  { top: 75%; left: 6.7%; }
  .pos-10 { top: 25%; left: 6.7%; }

  /* Alineación de texto según posición */
  .pos-12 .node-text-{{ section.id }} { bottom: 120%; text-align: center; }
  .pos-2 .node-text-{{ section.id }}  { left: 120%; text-align: left; }
  .pos-4 .node-text-{{ section.id }}  { left: 120%; text-align: left; }
  .pos-6 .node-text-{{ section.id }}  { top: 120%; text-align: center; }
  .pos-8 .node-text-{{ section.id }}  { right: 120%; text-align: right; }
  .pos-10 .node-text-{{ section.id }} { right: 120%; text-align: right; }

  @media screen and (max-width: 768px) {
    .clock-system-{{ section.id }} {
      width: 280px;
      height: 280px;
    }
    .node-text-{{ section.id }} { width: 100px; font-size: 12px; }
  }
{%- endstyle -%}

<div class="brand-statement-{{ section.id }}">
  <div class="container mx-auto px-6">
    <div class="brand-text-{{ section.id }} mb-10" style="font-family: {{ section.settings.font_family.family }};">
      {{ section.settings.content }}
    </div>

    <div class="clock-system-{{ section.id }}">
      <div class="brand-circle-{{ section.id }}">
        {%- if section.settings.circle_image != blank -%}
          <img src="{{ section.settings.circle_image | image_url: width: 800 }}" alt="Center Image">
        {%- endif -%}
      </div>

      {%- for block in section.blocks -%}
        <div class="clock-node-{{ section.id }} pos-{{ block.settings.position }}" {{ block.shopify_attributes }}>
          <div class="node-dot-{{ section.id }}">
            {%- if block.settings.node_image != blank -%}
              <img src="{{ block.settings.node_image | image_url: width: 200 }}" alt="Node">
            {%- endif -%}
          </div>
          {%- if block.settings.node_text != blank -%}
            <div
              class="node-text-{{ section.id }}"
              style="font-family: {{ section.settings.node_font_family.family }};"
            >
              {{ block.settings.node_text }}
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Brand Clock Statement",
  "max_blocks": 6,
  "settings": [
    { "type": "header", "content": "Sección" },
    { "type": "color", "id": "bg_color", "label": "Fondo Sección", "default": "#ffffff" },
    {
      "type": "range",
      "id": "padding_v",
      "min": 50,
      "max": 400,
      "step": 10,
      "unit": "px",
      "label": "Espaciado Vertical",
      "default": 100
    },
    {
      "type": "select",
      "id": "horizontal_alignment",
      "label": "Alineación",
      "options": [
        { "value": "left", "label": "Izquierda" },
        { "value": "center", "label": "Centro" },
        { "value": "right", "label": "Derecha" }
      ],
      "default": "center"
    },
    { "type": "richtext", "id": "content", "label": "Texto Introducción" },
    { "type": "font_picker", "id": "font_family", "label": "Fuente Intro", "default": "assistant_n4" },

    { "type": "header", "content": "Círculo Central" },
    { "type": "image_picker", "id": "circle_image", "label": "Imagen Centro" },
    {
      "type": "range",
      "id": "circle_size",
      "min": 200,
      "max": 800,
      "step": 10,
      "unit": "px",
      "label": "Tamaño Círculo",
      "default": 400
    },
    { "type": "color", "id": "circle_border_color", "label": "Color Borde", "default": "#000000" },
    {
      "type": "range",
      "id": "circle_border_width",
      "min": 0,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Grosor Borde",
      "default": 2
    },
    { "type": "color", "id": "circle_bg_color", "label": "Color Relleno", "default": "transparent" },
    {
      "type": "range",
      "id": "inner_image_width",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Tamaño Imagen Centro",
      "default": 70
    },
    {
      "type": "range",
      "id": "circle_margin_top",
      "min": 0,
      "max": 200,
      "step": 10,
      "unit": "px",
      "label": "Margen superior sistema",
      "default": 100
    },

    { "type": "header", "content": "Ajuste de los Puntos (Nodos)" },
    { "type": "color", "id": "dot_color", "label": "Color de los Puntos", "default": "#000000" },
    {
      "type": "range",
      "id": "dot_size",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Tamaño de los Puntos",
      "default": 30
    },
    { "type": "color", "id": "node_text_color", "label": "Color Texto Nodos", "default": "#000000" },
    { "type": "font_picker", "id": "node_font_family", "label": "Fuente Nodos", "default": "assistant_n4" },
    {
      "type": "range",
      "id": "node_font_size",
      "min": 10,
      "max": 40,
      "step": 1,
      "unit": "px",
      "label": "Tamaño Texto Nodos",
      "default": 16
    },
    {
      "type": "select",
      "id": "node_font_weight",
      "label": "Peso Texto",
      "options": [
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Normal" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "400"
    },
    {
      "type": "select",
      "id": "node_text_transform",
      "label": "Mayúsculas",
      "options": [
        { "value": "none", "label": "No" },
        { "value": "uppercase", "label": "Sí" }
      ],
      "default": "none"
    },
    {
      "type": "select",
      "id": "node_font_style",
      "label": "Estilo",
      "options": [
        { "value": "normal", "label": "Normal" },
        { "value": "italic", "label": "Itálica" }
      ],
      "default": "normal"
    }
  ],
  "blocks": [
    {
      "type": "point",
      "name": "Punto (Hora)",
      "settings": [
        {
          "type": "select",
          "id": "position",
          "label": "Posición (Hora Reloj)",
          "options": [
            { "value": "12", "label": "12:00 (Arriba)" },
            { "value": "2", "label": "02:00" },
            { "value": "4", "label": "04:00" },
            { "value": "6", "label": "06:00 (Abajo)" },
            { "value": "8", "label": "08:00" },
            { "value": "10", "label": "10:00" }
          ],
          "default": "12"
        },
        { "type": "textarea", "id": "node_text", "label": "Texto del Punto" },
        { "type": "image_picker", "id": "node_image", "label": "Imagen dentro del punto (opcional)" }
      ]
    }
  ],
  "presets": [{ "name": "Brand Clock Statement" }]
}
{% endschema %}
