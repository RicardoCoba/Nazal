    {
      "type": "range",
      "id": "node_icon_width",
      "min": 10,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Tamaño Icono",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Beneficio",
      "settings": [
        {
          "type": "select",
          "id": "position",
          "label": "Hora",
          "options": [
            { "value": "12", "label": "12:00" },
            { "value": "2", "label": "02:00" },
            { "value": "4", "label": "04:00" },
            { "value": "6", "label": "06:00" },
            { "value": "8", "label": "08:00" },
            { "value": "10", "label": "10:00" }
