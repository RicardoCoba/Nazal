    { "type": "richtext", "id": "content", "label": "Texto Principal" },
    { "type": "font_picker", "id": "font_family", "label": "Fuente Principal", "default": "assistant_n4" },
    {
      "type": "range",
      "id": "font_size",
      "min": 10,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Tamaño Fuente",
      "default": 24
    },
    {
      "type": "range",
      "id": "content_max_width",
      "min": 300,
      "max": 1200,
      "step": 50,
      "unit": "px",
      "label": "Ancho Máximo",
      "default": 600
    },
    {
      "type": "range",
      "id": "logo_margin_bottom",
      "min": 0,
      "max": 200,
      "step": 10,
      "unit": "px",
      "label": "Margen abajo cabecera",
      "default": 60
    },
    { "type": "header", "content": "Círculo de Producto" },
    { "type": "image_picker", "id": "circle_image", "label": "Imagen del Producto (Centro)" },
    {
      "type": "range",
      "id": "circle_size",
      "min": 200,
      "max": 800,
      "step": 20,
      "unit": "px",
      "label": "Diámetro Círculo",
      "default": 400
    },
    {
      "type": "range",
      "id": "circle_border_width",
      "min": 1,
      "max": 10,
      "step": 1,
      "unit": "px",
      "label": "Grosor Línea",
      "default": 1
    },
    {
      "type": "range",
      "id": "inner_image_width",
      "min": 10,
      "max": 150,
      "step": 5,
      "unit": "%",
      "label": "Escala Imagen Producto",
      "default": 80
    },
    {
      "type": "range",
      "id": "circle_margin_top",
      "min": 0,
      "max": 200,
      "step": 10,
      "unit": "px",
      "label": "Margen Superior",
      "default": 40
    },
    { "type": "header", "content": "Estilo de los Beneficios" },
    {
      "type": "range",
      "id": "node_distance",
      "min": 10,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Distancia Texto",
      "default": 30
    },
    {
      "type": "select",
      "id": "content_block_align",
      "label": "Alineación",
      "options": [
        { "value": "flex-start", "label": "Izquierda" },
        { "value": "center", "label": "Centro" },
        { "value": "flex-end", "label": "Derecha" }
