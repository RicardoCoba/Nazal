{%- style -%}
  /* --- ANIMACIÓN LÁMPARA DE LAVA --- */
  @keyframes lava-animation {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  .brand-statement-{{ section.id }} {
    /* Fondo estilo lámpara de lava con gradientes */
    background: linear-gradient(-45deg, #000000, #1a1a1a, #434343, #000000);
    background-size: 400% 400%;
    animation: lava-animation 15s ease infinite;
    padding: {{ section.settings.padding_v }}px 0;
    text-align: center;
    overflow: hidden; /* Cambiado a hidden para que el brillo no se salga */
    position: relative;
  }

  /* --- CURSOR GLOW (EL PUNTO DIFUMINADO) --- */
  .cursor-glow-{{ section.id }} {
    position: fixed;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(255,255,255,0.15) 0%, rgba(255,255,255,0) 70%);
    border-radius: 50%;
    pointer-events: none;
    z-index: 2;
    transform: translate(-50%, -50%);
    mix-blend-mode: overlay; /* Esto hace que brille sobre el fondo */
    display: none;
  }

  .brand-header-{{ section.id }} {
    max-width: {{ section.settings.content_max_width }}px;
    margin: 0 auto {{ section.settings.logo_margin_bottom }}px auto;
    position: relative;
    z-index: 10;
  }

  .brand-logo-{{ section.id }} {
    width: {{ section.settings.logo_width }}px;
    height: auto;
    margin-bottom: 20px;
    display: inline-block;
    filter: drop-shadow(0 0 10px rgba(255,255,255,0.2));
  }

  /* TEXTO DINÁMICO: Blanco con Blend Mode para que reaccione a la lava */
  .brand-text-{{ section.id }}, .node-text-{{ section.id }} {
    color: #ffffff;
    mix-blend-mode: difference; /* El texto cambiará de tono según el fondo */
    position: relative;
    z-index: 10;
  }

  .brand-text-{{ section.id }} {
    font-size: {{ section.settings.font_size }}px;
    font-weight: {{ section.settings.font_weight }};
    text-transform: {{ section.settings.text_transform }};
    line-height: 1.2;
  }

  /* --- SISTEMA RELOJ --- */
  .circle-wrapper-{{ section.id }} {
    display: flex;
    justify-content: center;
    margin-top: {{ section.settings.circle_margin_top }}px;
    padding: 150px 0;
    position: relative;
    z-index: 5;
  }

  .circle-container-{{ section.id }} {
    position: relative;
    width: {{ section.settings.circle_size }}px;
    height: {{ section.settings.circle_size }}px;
    border: {{ section.settings.circle_border_width }}px solid rgba(255,255,255,0.1);
    border-radius: 50%;
    background-color: transparent;
    box-shadow: inset 0 0 50px rgba(0,0,0,0.5);
  }

  .center-image-{{ section.id }} {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: {{ section.settings.inner_image_width }}%;
    z-index: 1;
    pointer-events: none;
  }

  .center-image-{{ section.id }} img {
    width: 100%; height: auto; display: block;
    filter: drop-shadow(0 20px 30px rgba(0,0,0,0.5));
  }

  .clock-node-{{ section.id }} { position: absolute; width: 0; height: 0; z-index: 10; }

  .node-dot-{{ section.id }} {
    width: {{ section.settings.dot_size }}px !important;
    height: {{ section.settings.dot_size }}px !important;
    background-color: #ffffff !important;
    border-radius: 50% !important;
    position: absolute !important;
    transform: translate(-50%, -50%) !important;
    z-index: 20 !important;
    display: block !important;
    box-shadow: 0 0 15px rgba(255,255,255,0.5);
  }

  .node-content-{{ section.id }} {
    position: absolute;
    display: flex;
    flex-direction: column;
    gap: 10px;
    width: {{ section.settings.node_content_width }}px;
    align-items: {{ section.settings.content_block_align }};
    text-align: {{ section.settings.content_block_align | replace: 'flex-start', 'left' | replace: 'flex-end', 'right' }};
  }

  .node-text-{{ section.id }} {
    font-size: {{ section.settings.node_font_size }}px;
    font-weight: {{ section.settings.node_font_weight }};
    text-transform: {{ section.settings.node_text_transform }};
    line-height: 1.1;
    width: 100%;
  }

  .node-icon-{{ section.id }} img {
    width: {{ section.settings.node_icon_width }}px;
    height: auto;
    display: block;
    filter: grayscale(1) invert(1); /* Para que los iconos sean blancos */
  }

  /* Coordenadas */
  .pos-12 { top: 0%; left: 50%; }
  .pos-2  { top: 25%; left: 93.3%; }
  .pos-4  { top: 75%; left: 93.3%; }
  .pos-6  { top: 100%; left: 50%; }
  .pos-8  { top: 75%; left: 6.7%; }
  .pos-10 { top: 25%; left: 6.7%; }

  {%- assign dist = section.settings.node_distance -%}
  .pos-12 .node-content-{{ section.id }} { bottom: {{ dist }}px; left: 50%; transform: translateX(-50%); }
  .pos-2  .node-content-{{ section.id }} { left: {{ dist }}px; top: 0; transform: translateY(-50%); }
  .pos-4  .node-content-{{ section.id }} { left: {{ dist }}px; bottom: 0; transform: translateY(50%); }
  .pos-6  .node-content-{{ section.id }} { top: {{ dist }}px; left: 50%; transform: translateX(-50%); }
  .pos-8  .node-content-{{ section.id }} { right: {{ dist }}px; bottom: 0; transform: translateY(50%); }
  .pos-10 .node-content-{{ section.id }} { right: {{ dist }}px; top: 0; transform: translateY(-50%); }

  @media screen and (max-width: 768px) {
    .circle-wrapper-{{ section.id }} { transform: scale(0.65); padding: 40px 0; }
    .node-content-{{ section.id }} { width: 100px !important; }
    .cursor-glow-{{ section.id }} { display: none !important; }
  }
{%- endstyle -%}

<div class="brand-statement-{{ section.id }}" id="Section-{{ section.id }}">
  <div class="cursor-glow-{{ section.id }}" id="Cursor-{{ section.id }}"></div>

  <div class="container mx-auto px-6">
    <div
      class="brand-header-{{ section.id }}"
      style="font-family: {{ section.settings.font_family.family }}, sans-serif;"
    >
      {%- if section.settings.logo != blank -%}
        <img src="{{ section.settings.logo | image_url: width: 600 }}" class="brand-logo-{{ section.id }}" alt="Logo">
      {%- endif -%}
      {%- if section.settings.content != blank -%}
        <div class="brand-text-{{ section.id }}">
          {{ section.settings.content }}
        </div>
      {%- endif -%}
    </div>

    <div class="circle-wrapper-{{ section.id }}">
      <div class="circle-container-{{ section.id }}">
        <div class="center-image-{{ section.id }}">
          {%- if section.settings.circle_image != blank -%}
            <img src="{{ section.settings.circle_image | image_url: width: 1000 }}" alt="Center Product">
          {%- endif -%}
        </div>

        {%- for block in section.blocks -%}
          <div class="clock-node-{{ section.id }} pos-{{ block.settings.position }}" {{ block.shopify_attributes }}>
            <div class="node-dot-{{ section.id }}">&nbsp;</div>
            <div
              class="node-content-{{ section.id }}"
              style="font-family: {{ section.settings.node_font_family.family }}, sans-serif;"
            >
              {%- if block.settings.node_text != blank -%}
                <div class="node-text-{{ section.id }}">
                  {{ block.settings.node_text | escape }}
                </div>
              {%- endif -%}
              {%- if block.settings.node_image != blank -%}
                <div class="node-icon-{{ section.id }}">
                  <img src="{{ block.settings.node_image | image_url: width: 300 }}" alt="Icon">
                </div>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const section = document.getElementById('Section-{{ section.id }}');
    const cursor = document.getElementById('Cursor-{{ section.id }}');

    section.addEventListener('mousemove', (e) => {
      cursor.style.display = 'block';
      // Ajuste de posición para que el brillo siga al mouse
      const x = e.clientX;
      const y = e.clientY;
      cursor.style.left = x + 'px';
      cursor.style.top = y + 'px';
    });

    section.addEventListener('mouseleave', () => {
      cursor.style.display = 'none';
    });
  });
</script>

{% schema %}
{
  "name": "Brand Circular Feature",
  "settings": [
    { "type": "header", "content": "Sección" },
    { "type": "color", "id": "bg_color", "label": "Color Base (Fondo)", "default": "#000000" },
    {
      "type": "range",
      "id": "padding_v",
      "min": 0,
      "max": 400,
      "step": 10,
      "unit": "px",
      "label": "Padding Vertical",
      "default": 100
    },
    { "type": "header", "content": "Logo y Texto Superior" },
    { "type": "image_picker", "id": "logo", "label": "Logo" },
    {
      "type": "range",
      "id": "logo_width",
      "min": 50,
      "max": 400,
      "step": 10,
      "unit": "px",
      "label": "Ancho Logo",
      "default": 150
