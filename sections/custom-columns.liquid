{%- style -%}
  .hero-divider-{{ section.id }} {
    position: relative;
    min-height: {{ section.settings.section_height }}vh;
    display: flex;
    align-items: {{ section.settings.content_vertical_alignment }};
    justify-content: {{ section.settings.content_horizontal_alignment }};
    overflow: hidden;
    padding: 60px 20px;
  }

  /* FONDO */
  .hero-bg-{{ section.id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .hero-bg-{{ section.id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-overlay-{{ section.id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ section.settings.overlay_color }};
    opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    z-index: 2;
  }

  /* CONTENIDO */
  .hero-content-{{ section.id }} {
    position: relative;
    z-index: 10;
    max-width: {{ section.settings.content_max_width }}px;
    display: flex;
    flex-direction: column;
    align-items: {{ section.settings.text_align | replace: 'left', 'flex-start' | replace: 'right', 'flex-end' }};
    text-align: {{ section.settings.text_align }};
  }

  .text-line-group-{{ section.id }} {
    display: flex;
    flex-direction: column;
    align-items: inherit;
    margin-bottom: {{ section.settings.logo_margin_top }}px;
    width: 100%;
  }

  .hero-title-{{ section.id }} {
    color: {{ section.settings.title_color }};
    font-size: {{ section.settings.title_size }}px;
    font-family: {{ section.settings.font_family.family }}, sans-serif;
    font-weight: {{ section.settings.font_weight }};
    font-style: {{ section.settings.font_style }};
    line-height: {{ section.settings.line_height }}; /* CONTROL DE INTERLINEADO */
    margin: 0 0 {{ section.settings.line_margin_top }}px 0;
    text-transform: {{ section.settings.text_transform }};
  }

  .hero-line-{{ section.id }} {
    width: {{ section.settings.line_width }}px;
    height: {{ section.settings.line_thickness }}px;
    background-color: {{ section.settings.line_color }};
    border: none;
    margin: 0;
  }

  .hero-logo-{{ section.id }} {
    width: {{ section.settings.logo_width }}px;
    height: auto;
    display: block;
  }

  @media screen and (max-width: 768px) {
    .hero-title-{{ section.id }} {
      font-size: calc({{ section.settings.title_size }}px * 0.7);
    }
  }
{%- endstyle -%}

<section class="hero-divider-{{ section.id }}">
  <div class="hero-bg-{{ section.id }}">
    {%- if section.settings.bg_image != blank -%}
      <img src="{{ section.settings.bg_image | image_url: width: 2000 }}" alt="{{ section.settings.bg_image.alt }}">
    {%- else -%}
      <div style="background: #1a1a1a; width: 100%; height: 100%;"></div>
    {%- endif -%}
    <div class="hero-overlay-{{ section.id }}"></div>
  </div>

  <div class="hero-content-{{ section.id }}">
    <div class="text-line-group-{{ section.id }}">
      {%- if section.settings.title != blank -%}
        <h2 class="hero-title-{{ section.id }}">{{ section.settings.title | newline_to_br }}</h2>
      {%- endif -%}
      <hr class="hero-line-{{ section.id }}">
    </div>

    {%- if section.settings.logo != blank -%}
      <img src="{{ section.settings.logo | image_url: width: 400 }}" class="hero-logo-{{ section.id }}" alt="Logo">
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Hero Marca con Divisor",
  "settings": [
    {
      "type": "header",
      "content": "Fondo"
    },
    { "type": "image_picker", "id": "bg_image", "label": "Imagen de Fondo" },
    {
      "type": "range",
      "id": "section_height",
      "min": 40,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "label": "Altura de Sección",
      "default": 80
    },
    { "type": "color", "id": "overlay_color", "label": "Color Filtro", "default": "#000000" },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 90,
      "step": 5,
      "unit": "%",
      "label": "Opacidad Filtro",
      "default": 40
    },
    {
      "type": "header",
      "content": "Contenido"
    },
    { "type": "textarea", "id": "title", "label": "Título", "default": "TU TÍTULO\nAQUÍ" },
    { "type": "image_picker", "id": "logo", "label": "Logo (Abajo)" },
    {
      "type": "range",
      "id": "logo_width",
      "min": 30,
      "max": 400,
      "step": 5,
      "unit": "px",
      "label": "Ancho Logo",
      "default": 100
    },
    {
      "type": "range",
      "id": "content_max_width",
      "min": 300,
      "max": 1400,
      "step": 50,
      "unit": "px",
      "label": "Ancho Máx Contenido",
      "default": 800
    },
    {
      "type": "header",
      "content": "Tipografía Avanzada"
    },
    { "type": "font_picker", "id": "font_family", "label": "Fuente", "default": "assistant_n4" },
    { "type": "color", "id": "title_color", "label": "Color Texto", "default": "#ffffff" },
    {
      "type": "range",
      "id": "title_size",
      "min": 20,
      "max": 120,
      "step": 2,
      "unit": "px",
      "label": "Tamaño Texto",
      "default": 42
    },
    {
      "type": "range",
      "id": "line_height",
      "min": 0.8,
      "max": 2.0,
      "step": 0.1,
      "label": "Interlineado (Line Height)",
      "default": 1.1
    },
    {
      "type": "select",
      "id": "font_style",
      "label": "Estilo de Fuente",
      "options": [
        { "value": "normal", "label": "Normal" },
        { "value": "italic", "label": "Itálica" }
      ],
      "default": "italic"
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Peso Texto",
      "options": [
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Normal" },
        { "value": "700", "label": "Bold" },
        { "value": "900", "label": "Black" }
      ],
      "default": "700"
    },
    {
      "type": "select",
      "id": "text_transform",
      "label": "Mayúsculas",
      "options": [
        { "value": "none", "label": "No" },
        { "value": "uppercase", "label": "Sí" }
      ],
      "default": "uppercase"
    },
    {
      "type": "header",
      "content": "Espaciado y Línea"
    },
    {
      "type": "range",
      "id": "line_margin_top",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "label": "Distancia Texto -> Línea",
      "default": 8
    },
    {
      "type": "range",
      "id": "logo_margin_top",
      "min": 10,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Distancia Grupo -> Logo",
      "default": 60
    },
    { "type": "color", "id": "line_color", "label": "Color Línea", "default": "#ffffff" },
    {
      "type": "range",
      "id": "line_width",
      "min": 10,
      "max": 600,
      "step": 10,
      "unit": "px",
      "label": "Ancho Línea",
      "default": 120
    },
    {
      "type": "range",
      "id": "line_thickness",
      "min": 1,
      "max": 10,
      "step": 1,
      "unit": "px",
      "label": "Grosor Línea",
      "default": 2
    },
    {
      "type": "header",
      "content": "Posicionamiento"
    },
    {
      "type": "select",
      "id": "content_vertical_alignment",
      "label": "Posición Vertical",
      "options": [
        { "value": "flex-start", "label": "Arriba" },
        { "value": "center", "label": "Centro" },
        { "value": "flex-end", "label": "Abajo" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "content_horizontal_alignment",
      "label": "Posición Horizontal",
      "options": [
        { "value": "flex-start", "label": "Izquierda" },
        { "value": "center", "label": "Centro" },
        { "value": "flex-end", "label": "Derecha" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Alineación Texto",
      "options": [
        { "value": "left", "label": "Izquierda" },
        { "value": "center", "label": "Centro" },
        { "value": "right", "label": "Derecha" }
      ],
      "default": "center"
    }
  ],
  "presets": [{ "name": "Hero Marca con Divisor" }]
}
{% endschema %}
